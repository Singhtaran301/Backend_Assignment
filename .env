# --- APP SETTINGS ---
ENVIRONMENT=development
# Just a random string for dev
SECRET_KEY=dev_secret_key_123
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
LOG_LEVEL=INFO

# --- DATABASE ---
# CRITICAL: In Docker, the host is the service name 'db', NOT 'localhost'
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/amrutam

# --- REDIS ---
# CRITICAL: In Docker, the host is 'redis', NOT 'localhost'
REDIS_URL=redis://redis:6379/0